---
import { DashboardApp } from "@/components/dashboard/DashboardApp";
import { getExpenseDataset } from "@/data/expense-data";
import BaseLayout from "@/layouts/BaseLayout.astro";

const dataset = getExpenseDataset();
---

<BaseLayout
  title="Expense Analyzer Categories"
  description="Category analysis for total spend, share of wallet, and monthly category trends."
>
  <DashboardApp client:only="react" page="categories" dataset={dataset} />
</BaseLayout>
