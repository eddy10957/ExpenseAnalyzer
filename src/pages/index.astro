---
import { DashboardApp } from "@/components/dashboard/DashboardApp";
import { getExpenseDataset } from "@/data/expense-data";
import BaseLayout from "@/layouts/BaseLayout.astro";

const dataset = getExpenseDataset();
---

<BaseLayout
  title="Expense Analyzer Overview"
  description="Overview dashboard for personal cashflow, expenses, and monthly trends."
>
  <DashboardApp client:only="react" page="overview" dataset={dataset} />
</BaseLayout>
