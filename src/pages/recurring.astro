---
import { DashboardApp } from "@/components/dashboard/DashboardApp";
import { getExpenseDataset } from "@/data/expense-data";
import BaseLayout from "@/layouts/BaseLayout.astro";

const dataset = getExpenseDataset();
---

<BaseLayout
  title="Expense Analyzer Recurring"
  description="Recurring charge and subscription analysis for repeat expense patterns."
>
  <DashboardApp client:only="react" page="recurring" dataset={dataset} />
</BaseLayout>
