---
import { DashboardApp } from "@/components/dashboard/DashboardApp";
import { getExpenseDataset } from "@/data/expense-data";
import BaseLayout from "@/layouts/BaseLayout.astro";

const dataset = getExpenseDataset();
---

<BaseLayout
  title="Expense Analyzer Insights"
  description="Narrative insights and optimization opportunities extracted from your spending patterns."
>
  <DashboardApp client:only="react" page="insights" dataset={dataset} />
</BaseLayout>
